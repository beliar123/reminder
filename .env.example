# Database
DATABASE_URL=postgresql+asyncpg://reminder:reminder@postgres:5432/reminder

# API
SECRET_KEY=change-me-to-a-long-random-secret

# Redis (for ARQ worker)
REDIS_URL=redis://redis:6379

# SMTP (for email reminders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=reminders@example.com

# Gunicorn
WEB_CONCURRENCY=4

# nginx (host machine config — used in nginx/reminder.conf)
DOMAIN=example.com
